# Backend production env — copy to `.env.production` and fill in the real values.
# Consumed via `env_file` in docker-compose.prod.yml. NEVER commit the filled file.

# --- Server ---
PORT=3000
# Frontend origin allowed by CORS.
#  - Split deploy (Vercel + Render): set to your Vercel domain, e.g. https://ncism.vercel.app
#    (REQUIRED — cross-origin, so CORS is enforced).
#  - Same-host deploy (compose): same-origin proxy makes this moot; any value is fine.
# On Render, this + DATABASE_URL + JWT_SECRET come from render.yaml / the dashboard, not this file.
CORS_ORIGIN=https://ncism.vercel.app

# --- Extraction (fast = native Java engine only; no Docling server, no GPU) ---
EXTRACTION_MODE=fast
# Path inside the backend image (set by the Dockerfile — do not change).
OPENDATALOADER_CLI_PATH=/opt/odl/bin/opendataloader-pdf

# --- Job storage ---
# Keep uploaded reports so the in-app PDF viewer / Documents tab keeps working
# for old cases (retention would otherwise purge job dirs after N hours).
KEEP_JOBS=true
JOB_RETENTION_HOURS=24

# --- Uploads ---
MAX_UPLOAD_MB=100

# --- Database (host = the `db` compose service) ---
# Use a STRONG password and keep it identical in DATABASE_URL and POSTGRES_PASSWORD.
DATABASE_URL=postgresql://ncism:CHANGE_ME_STRONG_PW@db:5432/ncism
POSTGRES_USER=ncism
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PW
POSTGRES_DB=ncism
POSTGRES_PORT=5432

# --- Auth — REGENERATE for every environment: openssl rand -hex 48 ---
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_48
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12
