# Frontend production env — VITE_* vars are baked in at build time (vite build).
#
# SPLIT DEPLOY (Vercel frontend + Render backend): different origins, so the API URL
# must be ABSOLUTE. Set this in the Vercel project's Environment Variables (not this file):
VITE_API_URL=https://ncism-backend.onrender.com/api/v1
#
# SAME-HOST DEPLOY (docker-compose.prod.yml): nginx proxies /api/v1 same-origin, so the
# compose build arg overrides this to a relative "/api/v1" — nothing to change here.
