# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Extraction
# fast   = native Java engine only (default; recommended for born-digital
#          NCISM reports — no Docling server, no GPU)
# hybrid = route complex pages through the Docling backend (scanned or
#          borderless documents); requires the hybrid server below
EXTRACTION_MODE=fast
# Hybrid (Docling) server used when EXTRACTION_MODE=hybrid
HYBRID_SERVER_URL=http://localhost:5002
# Structured markdown renderer: 'cdm' (default, Canonical Document Model) or
# 'legacy' (old reconstruction output)
CDM_RENDERER=cdm
# Path to the opendataloader-pdf CLI executable
OPENDATALOADER_CLI_PATH=D:\opendataloader-pdf\.venv\Scripts\opendataloader-pdf.exe

# Job storage
# Hours before a job directory is purged (ignored when KEEP_JOBS=true)
JOB_RETENTION_HOURS=24
KEEP_JOBS=false

# Uploads
MAX_UPLOAD_MB=100

# --- Database (Phase 0) ---
# Postgres via docker-compose (repo root: `docker compose up -d db`).
DATABASE_URL=postgresql://ncism:ncism_dev_pw@localhost:5432/ncism
# Used by docker-compose.yml (override the dev defaults for real deployments):
POSTGRES_USER=ncism
POSTGRES_PASSWORD=ncism_dev_pw
POSTGRES_DB=ncism
POSTGRES_PORT=5432
# TEST_DATABASE_URL=postgresql://ncism:ncism_dev_pw@localhost:5432/ncism_test

# --- Auth (Phase 1) ---
# CHANGE in every real environment. Generate: openssl rand -hex 48
JWT_SECRET=dev-only-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12
